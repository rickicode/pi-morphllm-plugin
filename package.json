{
  "name": "pi-morphllm-plugin",
  "version": "0.1.4",
  "description": "Morph runtime extension package for Pi Coding Agent with tools, hooks, and compaction",
  "type": "module",
  "author": "rickicode",
  "homepage": "https://github.com/rickicode/pi-morphllm-plugin",
  "bugs": {
    "url": "https://github.com/rickicode/pi-morphllm-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rickicode/pi-morphllm-plugin.git"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi.dev",
    "morph",
    "plugin",
    "extension"
  ],
  "main": "./extensions/morph/index.js",
  "files": [
    "extensions",
    "prompts",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions/morph/index.js"
    ],
    "prompts": [
      "./prompts/morph-tools.md"
    ]
  },
  "scripts": {
    "test": "node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "@morphllm/morphsdk": "^0.2.160"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "license": "MIT"
}
